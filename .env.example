# ----------------------------------------------------------------------------
# Local development env. Copy to .env and fill in real values.
# In production (Azure Container Apps), these are injected from Key Vault refs
# and Container App secrets — do NOT commit a real .env.
# ----------------------------------------------------------------------------

# Master / fallback BYOK keys (optional — users can also pass via x-* headers)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Optimizer model (defaults to gpt-4o-mini)
OPTIMIZER_MODEL=gpt-4o-mini

# --- Production (Azure) only — leave blank for local SQLite/disk dev ---

# Postgres (Azure Flexible Server, private VNet endpoint)
# DB_HOST=opto-pg-XXXXXX.postgres.database.azure.com
# DB_USER=optoadmin
# DB_NAME=opto
# DB_PORT=5432
# DB_PASSWORD=<from Key Vault secretref:db-password>

# Azure Blob Storage (multi-modal stub uploads)
# AZURE_STORAGE_ACCOUNT_URL=https://optostorXXXXXX.blob.core.windows.net
# AZURE_BLOB_CONTAINER=multimodal-blobs

# Azure Key Vault (BYOK envelope encryption master key)
# AZURE_KEY_VAULT_URI=https://opto-kv-XXXXXX.vault.azure.net/
# BYOK_MASTER_KEY_SECRET_NAME=byok-master-key

# DefaultAzureCredential — UAMI client ID for managed identity auth
# AZURE_CLIENT_ID=<UAMI clientId>

# Local-dev escape hatch for BYOK encryption (base64 of 32-byte key)
# BYOK_MASTER_KEY_B64=
